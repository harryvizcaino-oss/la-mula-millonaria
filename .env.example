# ── Supabase (auth + database del juego) ──────────────────────
VITE_SUPABASE_URL=           # Project URL (https://<project-ref>.supabase.co)
VITE_SUPABASE_ANON_KEY=      # anon public key (Project Settings → API)

# ── Clerk Auth (legacy — el backend tRPC/MySQL aún lo usa) ────
VITE_CLERK_PUBLISHABLE_KEY=  # Clerk frontend key (pk_test_... or pk_live_...)
CLERK_SECRET_KEY=            # Clerk backend key (sk_test_... or sk_live_...)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=                # MySQL connection string (mysql://user:pass@host:port/db)

# ── Admin Role ──────────────────────────────────────────────────
OWNER_CLERK_ID=              # Clerk user ID of the app creator; gets role "admin" on first login
